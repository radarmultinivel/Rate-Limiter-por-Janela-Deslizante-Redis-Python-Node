{
  "name": "rate-limiter-sliding-window-log",
  "version": "1.0.0",
  "description": "Middleware de rate limiting com Sliding Window Log e Redis para proteção de APIs contra abusos e ataques DDoS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stress": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
